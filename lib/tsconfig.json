{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist/esm",
    "moduleResolution": "Node",
    "target": "ESNext",
    "module": "ESNext",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
