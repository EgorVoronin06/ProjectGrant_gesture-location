  "scripts": {
    "build": "tsc --build tsconfig.json tsconfig.cjs.json tsconfig.types.json",
    "dev": "tsc --build tsconfig.json tsconfig.cjs.json tsconfig.types.json --watch",
    "clean": "rimraf ./dist"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
